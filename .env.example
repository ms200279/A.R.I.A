# ────────────────────────────────────────────────────────────────
# aria — 환경 변수 템플릿
# 실제 값은 .env.local 에 채우고, 절대 커밋하지 않는다.
# 브라우저에 노출되는 값만 NEXT_PUBLIC_ 접두사를 붙인다.
# ────────────────────────────────────────────────────────────────

# ---- Supabase (public, 브라우저 노출 허용) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Supabase (server only, 절대 브라우저 노출 금지) ----
SUPABASE_SERVICE_ROLE_KEY=

# ---- Supabase CLI / 로컬 마이그레이션 ----
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# ---- LLM / Assistant ----
# 현재 assistant 는 provider-agnostic 구조다.
# ASSISTANT_PROVIDER 로 어떤 provider 를 쓸지 선택한다. 기본값은 gemini.
#   - gemini : @google/genai, 기본
#   - openai : OpenAI Responses API (대체/폴백용)
# 서버 전용. 절대 브라우저 번들로 노출되지 않도록 NEXT_PUBLIC_ 접두사를 붙이지 않는다.
ASSISTANT_PROVIDER=gemini

# 메모(및 향후 문서/메일) 요약 백엔드. assistant 와 독립적으로 둘 수 있다.
#   - auto   : GEMINI_API_KEY 가 있으면 gemini, 없으면 rule_based_v1 (기본)
#   - gemini : 키 없으면 런타임에 rule 로 fallback + 감사 로그
#   - rule   : 항상 rule_based_v1 (오프라인/비용 0)
# 긴 본문 청크 크기 상한은 코드 상수 `lib/summarizers/config` 의 MAX_USER_CONTENT_CHARS.
# Gemini 호출 전 `lib/safety/summarize-provider-gate`(민감 패턴·리소스 종류)를 통과해야 한다.
SUMMARIZER_PROVIDER=auto

# Gemini (Google AI Studio / @google/genai)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (선택 provider — 값 비워두면 provider=openai 로 스위치했을 때 에러 반환)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Assistant 루프 1회당 tool call 재주입 한도 (안전상한). 기본 5.
# ASSISTANT_MAX_ITERATIONS=5

# ---- Google (Gmail, Calendar) — 후속 단계 ----
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=

# ---- 보조 기능 ----
# WEB_SEARCH_API_KEY=
# WEATHER_API_KEY=

# ---- 앱 ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
