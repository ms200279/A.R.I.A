# ────────────────────────────────────────────────────────────────
# aria — 환경 변수 템플릿
# 실제 값은 .env.local 에 채우고, 절대 커밋하지 않는다.
# 브라우저에 노출되는 값만 NEXT_PUBLIC_ 접두사를 붙인다.
# ────────────────────────────────────────────────────────────────

# ---- Supabase (public, 브라우저 노출 허용) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Supabase (server only, 절대 브라우저 노출 금지) ----
SUPABASE_SERVICE_ROLE_KEY=

# ---- Supabase CLI / 로컬 마이그레이션 ----
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# ---- LLM ----
# OpenAI Responses API 기반 assistant 구동용.
# 서버 전용. 절대 브라우저 번들로 노출되지 않도록 NEXT_PUBLIC_ 접두사를 붙이지 않는다.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
# Assistant 루프 1회당 tool call 재주입 한도 (안전상한).
# ASSISTANT_MAX_ITERATIONS=5

# ---- Google (Gmail, Calendar) — 후속 단계 ----
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=

# ---- 보조 기능 ----
# WEB_SEARCH_API_KEY=
# WEATHER_API_KEY=

# ---- 앱 ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
