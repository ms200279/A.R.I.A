# ────────────────────────────────────────────────────────────────
# aria — 환경 변수 템플릿
# 실제 값은 .env.local 에 채우고, 절대 커밋하지 않는다.
# ────────────────────────────────────────────────────────────────

# ---- Supabase (public) ----
# Supabase 대시보드 → Project Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Supabase (server only) ----
# service_role 키는 반드시 서버에서만 사용. 브라우저 번들에 절대 포함 금지.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase CLI 링크/마이그레이션용 (로컬 개발)
# Supabase 대시보드 URL 의 /project/<ref> 부분
SUPABASE_PROJECT_REF=
# `supabase db push` 등을 위한 DB 접속 비밀번호 (대시보드 > DB settings)
SUPABASE_DB_PASSWORD=

# ---- LLM (TODO: 공급자 확정 후 하나 선택) ----
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ---- Google (Gmail, Calendar) — 최소 스코프 ----
# 실제 연결은 후속 단계. 일단 자리만.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=

# ---- 보조 기능 ----
# WEB_SEARCH_API_KEY=
# WEATHER_API_KEY=

# ---- 앱 ----
# NEXT_PUBLIC_APP_URL=http://localhost:3000
